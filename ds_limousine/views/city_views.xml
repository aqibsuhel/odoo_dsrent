<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- City List View -->
    <record id="view_limousine_city_tree" model="ir.ui.view">
        <field name="name">limousine.city.tree</field>
        <field name="model">limousine.city</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="name_arabic"/>
                <field name="region_id"/>
                <field name="branch_count"/>
            </list>
        </field>
    </record>

    <!-- City Form View -->
    <record id="view_limousine_city_form" model="ir.ui.view">
        <field name="name">limousine.city.form</field>
        <field name="model">limousine.city</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="name_arabic"/>
                        <field name="region_id"/>
                    </group>
                    <notebook>
                        <page string="Branches">
                            <field name="branch_ids">
                                <list>
                                    <field name="name"/>
                                    <field name="name_arabic"/>
                                    <field name="phone"/>
                                    <field name="active"/>
                                </list>
                            </field>
                        </page>
                        <page string="Airports">
                            <field name="airport_ids">
                                <list>
                                    <field name="name"/>
                                    <field name="code"/>
                                    <field name="active"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- City Action -->
    <record id="action_limousine_city" model="ir.actions.act_window">
        <field name="name">Cities</field>
        <field name="res_model">limousine.city</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>