<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Limousine Booking Form View -->
    <record id="view_limousine_booking_form" model="ir.ui.view">
        <field name="name">limousine.booking.form</field>
        <field name="model">limousine.booking</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_confirm" string="Confirm" type="object"
                            invisible="state != 'draft'" class="btn-primary"/>
                    <button name="action_start" string="Start Service" type="object"
                            invisible="state != 'confirmed'" class="btn-primary"/>
                    <button name="action_complete" string="Complete" type="object"
                            invisible="state != 'in_progress'" class="btn-primary"/>
                    <button name="action_cancel" string="Cancel" type="object"
                            invisible="state in ['completed', 'cancelled']" class="btn-secondary"/>
                    <button name="action_set_to_draft" string="Set to Draft" type="object"
                            invisible="state != 'cancelled'" class="btn-secondary"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,confirmed,in_progress,completed"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_invoices" type="object"
                                class="oe_stat_button" icon="fa-pencil-square-o">
                            <field name="invoice_count" widget="statbutton" string="Invoices"/>
                        </button>
                    </div>
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="booking_type" required="1"/>
                            <field name="customer_id" required="1"
                                   options="{'no_create': True, 'no_create_edit': True}"/>
                            <field name="business_type"/>
                            <field name="booking_date"/>
                            <field name="payment_term"/>
                        </group>
                        <group>
                            <field name="region_id" options="{'no_create': True}"/>
                            <field name="city_id" options="{'no_create': True}"/>
                            <field name="branch_id" options="{'no_create': True}"/>
                            <field name="currency_id" invisible="1"/>
                        </group>
                    </group>

                    <notebook>
                        <!-- Services Tab - ENHANCED -->
                        <page string="Services" name="services">
                            <field name="service_line_ids" widget="one2many" mode="tree,kanban">
                                <tree editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="service_id" options="{'no_create': True}"/>

                                    <!-- Vehicle Selection - Main Feature -->
                                    <field name="vehicle_id"
                                           options="{'no_create': True, 'no_create_edit': True}"
                                           context="{'default_status': 'available'}"/>

                                    <!-- Vehicle Details (Auto-populated) -->
                                    <field name="vehicle_brand" optional="show"/>
                                    <field name="vehicle_model" optional="show"/>
                                    <field name="vehicle_year" optional="hide"/>
                                    <field name="vehicle_registration" optional="show"/>
                                    <field name="vehicle_seats" optional="hide"/>

                                    <!-- Manual Entry (if vehicle not in system) -->
                                    <field name="car_model_manual" optional="hide"/>
                                    <field name="car_model_display" optional="hide"/>

                                    <!-- Dates and Hours -->
                                    <field name="start_date" required="1"/>
                                    <field name="end_date" required="1"/>
                                    <field name="total_hours" readonly="1"/>
                                    <field name="duration"/>
                                    <field name="extra_hours" readonly="1" optional="show"/>

                                    <!-- Pricing -->
                                    <field name="suggested_hourly_rate" optional="hide"
                                           decoration-info="suggested_hourly_rate > 0"/>
                                    <field name="unit_price" required="1"/>
                                    <field name="quantity" optional="hide"/>
                                    <field name="misc_charges" optional="show"/>

                                    <!-- Tax and Discount -->
                                    <field name="tax_ids" widget="many2many_tags" optional="show"/>
                                    <field name="discount_percent" optional="show"/>
                                    <field name="discount_amount" readonly="1" optional="hide"/>

                                    <!-- Totals -->
                                    <field name="subtotal" readonly="1" sum="Subtotal"/>
                                    <field name="tax_amount" readonly="1" optional="show" sum="Tax"/>
                                    <field name="total" readonly="1" sum="Total"/>

                                    <!-- Additional -->
                                    <field name="guests_count" optional="hide"/>
                                    <field name="driver_id" optional="show"/>
                                    <field name="status" widget="badge"
                                           decoration-success="status == 'completed'"
                                           decoration-info="status == 'confirmed'"
                                           decoration-warning="status == 'in_progress'"/>
                                </tree>

                                <!-- Kanban View for Services -->
                                <kanban class="o_kanban_mobile">
                                    <templates>
                                        <t t-name="card">
                                            <div class="row">
                                                <div class="col-12">
                                                    <strong><field name="service_id"/></strong>
                                                </div>
                                                <div class="col-6">
                                                    <field name="vehicle_id"/>
                                                </div>
                                                <div class="col-6 text-end">
                                                    <field name="total" widget="monetary"/>
                                                </div>
                                                <div class="col-12">
                                                    <field name="start_date"/> - <field name="end_date"/>
                                                </div>
                                            </div>
                                        </t>
                                    </templates>
                                </kanban>

                                <!-- Form View for Service Line -->
                                <form>
                                    <sheet>
                                        <group>
                                            <group>
                                                <field name="service_id"/>
                                                <field name="vehicle_id"
                                                       options="{'no_create': True}"
                                                       context="{'default_status': 'available'}"/>
                                                <field name="car_model_manual"
                                                       invisible="vehicle_id"
                                                       placeholder="e.g., Toyota Camry 2024"/>
                                            </group>
                                            <group>
                                                <field name="vehicle_brand" readonly="1"/>
                                                <field name="vehicle_model" readonly="1"/>
                                                <field name="vehicle_year" readonly="1"/>
                                                <field name="vehicle_registration" readonly="1"/>
                                                <field name="vehicle_seats" readonly="1"/>
                                            </group>
                                        </group>

                                        <group>
                                            <group string="Schedule">
                                                <field name="start_date"/>
                                                <field name="end_date"/>
                                                <field name="total_hours" readonly="1"/>
                                                <field name="duration"/>
                                                <field name="extra_hours" readonly="1"/>
                                            </group>
                                            <group string="Pricing">
                                                <field name="suggested_hourly_rate" readonly="1"
                                                       invisible="not vehicle_id"/>
                                                <field name="unit_price"/>
                                                <field name="quantity"/>
                                                <field name="misc_charges"/>
                                            </group>
                                        </group>

                                        <group>
                                            <group string="Tax &amp; Discount">
                                                <field name="tax_ids" widget="many2many_tags"/>
                                                <field name="discount_percent"/>
                                                <field name="discount_amount" readonly="1"/>
                                            </group>
                                            <group string="Totals">
                                                <field name="subtotal" readonly="1"/>
                                                <field name="tax_amount" readonly="1"/>
                                                <field name="total" readonly="1"/>
                                            </group>
                                        </group>

                                        <group>
                                            <group string="Guest Information">
                                                <field name="guests_count"/>
                                                <field name="guest_names" placeholder="Enter guest names"/>
                                            </group>
                                            <group string="Assignment">
                                                <field name="driver_id"/>
                                                <field name="status"/>
                                            </group>
                                        </group>

                                        <group>
                                            <field name="notes" placeholder="Additional notes..."/>
                                        </group>
                                    </sheet>
                                </form>
                            </field>

                            <!-- Totals Summary -->
                            <group class="oe_subtotal_footer oe_right">
                                <field name="amount_untaxed" widget="monetary"/>
                                <field name="amount_tax" widget="monetary"/>
                                <div class="oe_subtotal_footer_separator oe_inline">
                                    <label for="amount_total"/>
                                    <button name="button_dummy" states="draft"
                                            string="(update)" type="object" class="oe_edit_only oe_link"/>
                                </div>
                                <field name="amount_total" widget="monetary" class="oe_subtotal_footer_separator"/>
                            </group>
                            <div class="clearfix"/>
                        </page>

                        <!-- Guest Details Tab -->
                        <page string="Guest Details" name="guest_details">
                            <group>
                                <group>
                                    <field name="guest_name"/>
                                    <field name="guest_mobile"/>
                                    <field name="guest_email"/>
                                </group>
                                <group>
                                    <field name="guest_id_number"/>
                                    <field name="guest_nationality"/>
                                    <field name="guest_passport"/>
                                </group>
                            </group>
                        </page>

                        <!-- Flight & Hotel Tab -->
                        <page string="Flight &amp; Hotel" name="flight_hotel">
                            <group>
                                <group string="Flight Information">
                                    <field name="flight_number"/>
                                    <field name="flight_date"/>
                                    <field name="departure_airport_id"/>
                                    <field name="arrival_airport_id"/>
                                </group>
                                <group string="Hotel Information">
                                    <field name="hotel_name"/>
                                    <field name="hotel_address"/>
                                    <field name="check_in_date"/>
                                    <field name="check_out_date"/>
                                </group>
                            </group>
                        </page>

                        <!-- Other Information -->
                        <page string="Other Information" name="other_info">
                            <group>
                                <group>
                                    <field name="company_id" groups="base.group_multi_company"/>
                                    <field name="user_id"/>
                                </group>
                                <group>
                                    <field name="notes" placeholder="Internal notes..."/>
                                </group>
                            </group>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- Limousine Booking List View -->
    <record id="view_limousine_booking_list" model="ir.ui.view">
        <field name="name">limousine.booking.list</field>
        <field name="model">limousine.booking</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="booking_date"/>
                <field name="customer_id"/>
                <field name="booking_type"/>
                <field name="city_id"/>
                <field name="branch_id"/>
                <field name="amount_total" sum="Total Amount"/>
                <field name="state" widget="badge"
                       decoration-success="state == 'completed'"
                       decoration-info="state == 'confirmed'"
                       decoration-warning="state == 'in_progress'"
                       decoration-muted="state == 'cancelled'"/>
            </list>
        </field>
    </record>

    <!-- Limousine Booking Search View -->
    <record id="view_limousine_booking_search" model="ir.ui.view">
        <field name="name">limousine.booking.search</field>
        <field name="model">limousine.booking</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="customer_id"/>
                <field name="booking_type"/>
                <field name="city_id"/>
                <separator/>
                <filter string="Draft" name="draft" domain="[('state', '=', 'draft')]"/>
                <filter string="Confirmed" name="confirmed" domain="[('state', '=', 'confirmed')]"/>
                <filter string="In Progress" name="in_progress" domain="[('state', '=', 'in_progress')]"/>
                <filter string="Completed" name="completed" domain="[('state', '=', 'completed')]"/>
                <separator/>
                <filter string="Booking Date" name="booking_date" date="booking_date"/>
                <group string="Group By">
                    <filter string="Customer" name="group_customer" context="{'group_by': 'customer_id'}"/>
                    <filter string="Booking Type" name="group_type" context="{'group_by': 'booking_type'}"/>
                    <filter string="City" name="group_city" context="{'group_by': 'city_id'}"/>
                    <filter string="Status" name="group_state" context="{'group_by': 'state'}"/>
                    <filter string="Booking Date" name="group_date" context="{'group_by': 'booking_date'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Limousine Booking Kanban View -->
    <record id="view_limousine_booking_kanban" model="ir.ui.view">
        <field name="name">limousine.booking.kanban</field>
        <field name="model">limousine.booking</field>
        <field name="arch" type="xml">
            <kanban class="o_kanban_mobile">
                <templates>
                    <t t-name="card">
                        <div class="oe_kanban_global_click">
                            <div class="row">
                                <div class="col-12">
                                    <strong><field name="name"/></strong>
                                    <span class="float-end">
                                        <field name="state" widget="badge"/>
                                    </span>
                                </div>
                                <div class="col-6">
                                    <field name="customer_id"/>
                                </div>
                                <div class="col-6 text-end">
                                    <field name="amount_total" widget="monetary"/>
                                </div>
                                <div class="col-12">
                                    <i class="fa fa-calendar"/> <field name="booking_date"/>
                                </div>
                                <div class="col-12">
                                    <i class="fa fa-map-marker"/> <field name="city_id"/>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- Limousine Booking Action -->
    <record id="action_limousine_booking" model="ir.actions.act_window">
        <field name="name">Bookings</field>
        <field name="res_model">limousine.booking</field>
        <field name="view_mode">list,form,kanban</field>
        <field name="context">{'search_default_draft': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first limousine booking
            </p>
            <p>
                Manage your limousine bookings with full vehicle tracking from your car rental fleet.
            </p>
        </field>
    </record>

</odoo>