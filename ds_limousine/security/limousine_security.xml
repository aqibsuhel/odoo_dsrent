<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">

        <!-- User Group -->
        <record id="group_limousine_user" model="res.groups">
            <field name="name">Limousine / User</field>
            <field name="comment">User access for limousine operations</field>
        </record>

        <!-- Manager Group -->
        <record id="group_limousine_manager" model="res.groups">
            <field name="name">Limousine / Manager</field>
            <field name="comment">Manager access for limousine operations</field>
            <field name="implied_ids" eval="[(4, ref('group_limousine_user'))]"/>
        </record>

        <!-- Record Rules -->
        <record id="limousine_booking_rule" model="ir.rule">
            <field name="name">Limousine Booking: multi-company</field>
            <field name="model_id" ref="model_limousine_booking"/>
            <field name="domain_force">['|', ('company_id', '=', False), ('company_id', 'in', company_ids)]</field>
        </record>

    </data>
</odoo>